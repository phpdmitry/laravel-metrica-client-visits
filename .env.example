# OAuth-токен пользователя Яндекса с правом metrika:read.
# Получите его по ссылке из README.md.
YANDEX_METRIKA_TOKEN=

# Номер счетчика Метрики.
YANDEX_METRIKA_COUNTER_ID=

# Необязательно: идентификатор OAuth-приложения. Скрипту он не нужен,
# но пригодится для формирования ссылки на получение токена.
YANDEX_OAUTH_CLIENT_ID=

